
GEMINI_API_KEY="MY_GEMINI_API_KEY"
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

APP_URL="MY_APP_URL"

# PRIVATE_KEY: The private key for the server-side wallet (for automated payments).
# Use a testnet wallet only!
PRIVATE_KEY=""

# RPC_URL: The RPC endpoint for the blockchain network (e.g., Sepolia).
RPC_URL="https://rpc.ankr.com/eth_sepolia"

# USDT_CONTRACT_ADDRESS: The address of the USDT contract on the chosen network (server-side).
USDT_CONTRACT_ADDRESS="0x7169D38820dfd117C3FA1f22a697dBA58d90BA06"

# ─── Frontend wallet config (Vite exposes VITE_ prefixed vars to the browser) ──

# VITE_TARGET_CHAIN_ID: Hex chain ID the wallet must be on.
# 0xaa36a7 = Sepolia testnet | 0x1 = Ethereum mainnet | 0x89 = Polygon
VITE_TARGET_CHAIN_ID="0xaa36a7"

# VITE_USDT_ADDRESS: ERC-20 USDT contract address visible to the frontend.
# Sepolia test USDT:  0x7169D38820dfd117C3FA1f22a697dBA58d90BA06
# Mainnet USDT:       0xdAC17F958D2ee523a2206206994597C13D831ec7
VITE_USDT_ADDRESS="0x7169D38820dfd117C3FA1f22a697dBA58d90BA06"
